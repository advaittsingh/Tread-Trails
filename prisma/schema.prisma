generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  admin
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum InboxKind {
  contact
  corporate
}

enum LeadSource {
  contact
  corporate
}

enum LeadStatus {
  new
  contacted
  qualified
  converted
  closed
}

enum LeadPriority {
  low
  normal
  high
  urgent
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  /// Normalized digits-only phone when set (see `lib/validations/phone`)
  phone        String?
  role         Role     @default(user)
  /// PDP/booking/catalog global selection — synced when signed in
  preferredVehicleSlug String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders               Order[]
  bookings             Booking[]
  savedVehicles        UserSavedVehicle[]
  wishlistProducts     UserWishlistProduct[]
  passwordResetTokens  PasswordResetToken[]
  assignedLeads        Lead[]           @relation("LeadAssignee")
  leadEmailsSent       LeadEmailLog[]   @relation("LeadEmailSender")
  mediaUploads         MediaAsset[]     @relation("MediaUploader")

  @@index([role])
}

/// Admin media library asset (Vercel Blob or Cloudinary).
model MediaAsset {
  id           String   @id @default(cuid())
  url          String   @unique
  storageKey   String?
  provider     String   @default("blob")
  filename     String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  folder       String   @default("uploads")
  tags         String[] @default([])
  altText      String?
  uploadedById String?
  uploadedBy   User?    @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([folder])
  @@index([createdAt])
  @@index([uploadedById])
}

model UserWishlistProduct {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productSlug String
  createdAt   DateTime @default(now())

  @@unique([userId, productSlug])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model UserSavedVehicle {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleSlug String
  createdAt   DateTime @default(now())

  @@unique([userId, vehicleSlug])
  @@index([userId])
}

/// OEM make (Toyota, Jeep) — not partner Brand.
model VehicleMake {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  models    VehicleModel[]

  @@index([sortOrder])
}

/// Model line under a make (Fortuner, Hilux).
model VehicleModel {
  id        String   @id @default(cuid())
  makeId    String
  make      VehicleMake @relation(fields: [makeId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicles  Vehicle[]

  @@unique([makeId, slug])
  @@index([makeId])
}

/// Fitment platform / generation (URL + compatibility unit).
model Vehicle {
  id               String   @id @default(cuid())
  legacyId         String?  @unique
  slug             String   @unique
  name             String
  tagline          String
  description      String   @default("")
  heroImage        String
  thumbnail        String
  category         String
  engineSummary    String   @default("")
  modelYearsLabel  String   @default("")
  trimSummary      String   @default("")
  modelId          String?
  model            VehicleModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  generationKey  String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productCompatibilities ProductVehicleCompatibility[]

  @@index([modelId])
  @@index([category])
}

/**
 * Portfolio case studies (mirrors `data/types` Build / `data/builds`).
 * Product linkage: canonical FK edges `PortfolioBuildProduct`; `productIds` (`text[]`) kept in sync
 * as legacy mirror / static fallback (tokens = static `Product.id` & seeded `Product.legacyId`).
 */
model PortfolioBuild {
  id           String   @id @default(cuid())
  legacyId     String?  @unique
  slug         String   @unique
  title        String
  vehicleSlug  String
  summary      String   @default("")
  description  String   @default("")
  beforeImage  String
  afterImage   String
  gallery      String[]
  /// Denormalized catalog tokens — duplicate of join targets for APIs without joins / static fallback.
  productIds   String[]
  /// Homepage portfolio strip: lower ranks first; null sorts last (see `listHomeFeaturedBuilds`).
  homeSpotlightRank Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  linkedProducts PortfolioBuildProduct[]

  @@index([vehicleSlug])
  @@index([homeSpotlightRank])
}

model PortfolioBuildProduct {
  id               String         @id @default(cuid())
  portfolioBuildId String
  productId        String
  sortOrder        Int            @default(0)
  portfolioBuild   PortfolioBuild @relation(fields: [portfolioBuildId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([portfolioBuildId, productId])
  @@index([productId])
}

/** Hub partner brands (Advven lineup); `productCount` recomputed on seed. */
model Brand {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  tagline      String   @default("")
  logoSrc      String   @default("")
  productCount Int      @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sortOrder])
}

/** Product ↔ Vehicle compatibility (many-to-many). Static catalog mirrors `product-vehicle-compatibility-edges.ts`. */
model ProductVehicleCompatibility {
  id        String   @id @default(cuid())
  productId String
  vehicleId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, vehicleId])
  @@index([vehicleId])
  @@index([productId])
}

model Product {
  id                     String   @id @default(cuid())
  legacyId               String?
  slug                   String   @unique
  name                   String
  brand                  String
  category               String
  price                  Int?
  currency               String   @default("INR")
  images                 String[]
  description            String   @default("")
  /// JSON array of `{ "label": string, "value": string }` (product specs / PDP). Default `[]`.
  specs                  Json     @default("[]")
  /// JSON array of `{ "id": string, "label": string, "priceModifier"?: number }`. PDP / cart; optional delta to base `price`. Default `[]`.
  variants               Json     @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  vehicleCompatibilities ProductVehicleCompatibility[]
  portfolioLinks         PortfolioBuildProduct[]
}

/// Customer orders: Stripe Checkout, Razorpay Checkout, Juspay hosted page, or COD — shipping captured at checkout; no courier PSP integration unless extended.
model Order {
  id                     String      @id @default(cuid())
  userId                 String?
  user                   User?       @relation(fields: [userId], references: [id])
  guestEmail             String?
  customerName           String
  customerPhone          String
  customerEmail          String
  /// Structured ship-to from checkout form — not forwarded to any carrier API in this codebase.
  shippingAddress        Json
  items                  Json
  total                  Int
  currency               String      @default("INR")
  status                 OrderStatus @default(pending)
  paymentMethod          String      @default("stripe")
  stripeCheckoutSessionId String?
  stripePaymentIntentId  String?
  razorpayOrderId        String?
  razorpayPaymentId      String?
  juspayGatewayOrderId   String?
  juspayCheckoutOrderRef String?
  /// Internal fulfilment / refund notes — admin only.
  fulfilmentNotes        String      @default("")
  trackingNumber         String?
  shippingCarrier        String?
  paidAt                 DateTime?
  shippedAt              DateTime?
  deliveredAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Booking {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  vehicleSlug  String
  vehicleName  String
  service      String
  date         String
  time         String
  contactName     String
  contactEmail    String
  contactPhone    String
  /// Optional note from the customer at booking time.
  customerMessage String        @default("")
  /// Internal studio notes — admin only.
  adminNotes      String        @default("")
  status          BookingStatus @default(pending)
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([createdAt])
}

model PageHit {
  id        String   @id @default(cuid())
  sessionId String
  path      String
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model PresenceSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  path        String   @default("/")
  userAgent   String   @default("")
  deviceType  String?
  deviceLabel String?
  ipHash      String   @default("")
  city        String?
  country     String?
  lat         Float?
  lng         Float?
  geoResolved Boolean  @default(false)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@index([lastSeenAt])
}

model CartTelemetry {
  id                    String   @id @default(cuid())
  sessionId             String   @unique
  lines                 Json     @default("[]")
  itemCount             Int      @default(0)
  subtotalHint          Int      @default(0)
  userEmail             String?
  customerName          String?
  lastPath              String   @default("")
  recoveryEmailSentAt   DateTime?
  recoveryWhatsappAt    DateTime?
  recoveryTemplate      String?
  recoveredAt           DateTime?
  convertedAt           DateTime?
  convertedOrderId      String?
  updatedAt             DateTime @default(now())

  recoveryLogs CartRecoveryLog[]

  @@index([updatedAt])
  @@index([recoveryEmailSentAt])
  @@index([convertedAt])
}

/// Audit trail for abandoned-cart recovery touches (email, WhatsApp, conversions).
model CartRecoveryLog {
  id        String   @id @default(cuid())
  sessionId String
  cart      CartTelemetry @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)
  channel   String
  action    String
  template  String?
  adminId   String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([adminId, createdAt])
}

model AppErrorLog {
  id        String   @id @default(cuid())
  severity  String   @default("error")
  category  String   @default("api")
  source    String
  route     String?
  message   String
  stack     String?
  detail    String?
  userId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([severity, createdAt])
  @@index([category, createdAt])
  @@index([route])
}

model InboxSubmission {
  id        String    @id @default(cuid())
  kind      InboxKind
  payload   Json
  emailSent Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  lead      Lead?

  @@index([kind, createdAt])
}

/// CRM lead — contact form and corporate inquiries with pipeline workflow.
model Lead {
  id                String       @id @default(cuid())
  source            LeadSource
  status            LeadStatus   @default(new)
  priority          LeadPriority @default(normal)
  displayName       String
  email             String
  phone             String?
  subject           String?
  message           String?
  companyName       String?
  contactPerson     String?
  businessType      String?
  requirements      String?
  adminNotes        String       @default("")
  assignedToId      String?
  assignedTo        User?        @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  inboxSubmissionId String?      @unique
  inboxSubmission   InboxSubmission? @relation(fields: [inboxSubmissionId], references: [id], onDelete: SetNull)
  contactedAt       DateTime?
  qualifiedAt       DateTime?
  convertedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  emailLogs         LeadEmailLog[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([priority])
  @@index([assignedToId])
  @@index([email])
}

model LeadEmailLog {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  adminId     String?
  admin       User?    @relation("LeadEmailSender", fields: [adminId], references: [id], onDelete: SetNull)
  to          String
  subject     String
  template    String?
  bodyPreview String?
  provider    String?
  messageId   String?
  createdAt   DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([adminId])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([adminId])
}

