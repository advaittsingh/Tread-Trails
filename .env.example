# Site (used in Stripe redirects & metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/tread-trails

# PostgreSQL (Neon) — Prisma uses this
# DATABASE_URL="postgresql://neondb_owner:npg_CxFg9v5jIcHL@ep-snowy-hall-aon24iv0-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth — minimum 16 characters in production
JWT_SECRET=change-me-to-a-long-random-string

# Stripe (Checkout + webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (admin CRM sends — verified domain required in production)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Tread Trails <notifications@yourdomain.com>"

# Optional: WhatsApp CTA (existing)
# NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Seed scripts (`npm run seed` catalog + optional admin, `npm run seed:admin` admin only)
# Default admin email for seed:admin is admin@treadtrails.com if SEED_ADMIN_EMAIL is omitted.
# SEED_ADMIN_EMAIL=admin@treadtrails.com
# SEED_ADMIN_PASSWORD=your-secure-password-at-least-8-chars
# SEED_ADMIN_NAME=Studio Admin
