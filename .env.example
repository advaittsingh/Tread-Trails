# Site (used in Stripe redirects & metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (Neon) — Prisma uses this
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth — minimum 16 characters in production
JWT_SECRET=change-me-to-a-long-random-string

# Stripe (Checkout + webhooks)
# Checkout UI exposes Stripe when STRIPE_SECRET_KEY is set. `paymentChannel: "stripe"` creates a Checkout Session.
# Currency is INR (whole rupees in catalog → paise on Stripe via lib/stripe `inrToStripeAmount`).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Production checklist:
# - STRIPE_SECRET_KEY — Dashboard → Developers → API keys → Secret key (live)
# - STRIPE_WEBHOOK_SECRET — Live webhook endpoint URL: https://YOUR_DOMAIN/api/webhooks/stripe (events: checkout.session.completed)
# - NEXT_PUBLIC_SITE_URL — https://YOUR_DOMAIN (no trailing slash); used for success_url / cancel_url and metadata links

# Razorpay (Checkout.js Orders API — INR)
# Server: RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET (Dashboard → API Keys)
# Browser Checkout.js needs the publishable Key Id:
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
# POST /api/orders/razorpay/verify finalizes payment after Checkout success handler (no Razorpay webhook required for MVP).

# Juspay (hosted payment page · Session API)
# JUSPAY_API_KEY=...
# JUSPAY_MERCHANT_ID=...
# JUSPAY_PAYMENT_PAGE_CLIENT_ID=...
# Uses POST https://api.juspay.in/session → redirect to payment_links.web; `/api/orders/juspay/sync` polls order status after return.

# Shipping / logistics — NOT integrated
# Checkout persists `shippingAddress` on each Order (JSON). Admins set fulfilment manually (`OrderStatus` includes `shipped` via /api/admin/orders).
# Confirmed absent: courier APIs (Shiprocket, Delhivery, Blue Dart, DTDC, etc.), rate/ETA APIs, AWB/tracking fields, label PDFs, carrier webhooks.

# Resend (admin CRM · POST /api/admin/email — requires admin session cookie)
# The app does NOT call Resend’s hosted “Templates” product unless you extend `app/api/admin/email/route.ts`.
# Today `template` is only `complete_order` | `interest` → inline HTML + subject in that route file.
#
# Production checklist:
# - RESEND_API_KEY — https://resend.com/api-keys (starts with re_)
# - RESEND_FROM_EMAIL — Must use an allowed sender: onboarding sends only work from onboarding@resend.dev in dev;
#   prod requires your verified domain in Resend, then e.g. "Tread Trails <notifications@yourdomain.com>"
# - Domain verification — Resend dashboard → Domains → add DNS records → verify before relying on CRM sends
# - Password reset emails (`POST /api/auth/forgot-password`) send to the user’s inbox via the same Resend key/from.
# Admin UI: /admin/crm — Admin › System shows whether RESEND_API_KEY is detected (not secret presence of FROM).
#
# Contact form (public POST /api/contact — no auth)
# Inbound mailbox for website submissions (reply-to is set to the visitor's email in Resend).
# CONTACT_TO_EMAIL=studio@yourdomain.com
#
# Optional — POST /api/corporate-inquiry inbox (defaults to CONTACT_TO_EMAIL if omitted)
# CORPORATE_TO_EMAIL=fleet@yourdomain.com

# Booking — studio civil clock (must match between server + browser bundles)
# Server: BOOKING_STUDIO_TIMEZONE + optional BOOKING_STUDIO_UTC_OFFSET_MINUTES (east of UTC, e.g. 330 for IST)
# Client: mirror with NEXT_PUBLIC_* so date/min/max and disabled slots match POST /api/bookings validation
# BOOKING_STUDIO_TIMEZONE=Asia/Kolkata
# BOOKING_STUDIO_UTC_OFFSET_MINUTES=330
# NEXT_PUBLIC_BOOKING_STUDIO_TIMEZONE=Asia/Kolkata
# NEXT_PUBLIC_BOOKING_STUDIO_UTC_OFFSET_MINUTES=330

# Optional: WhatsApp CTA (existing)
# NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Seed scripts (`npm run seed` → vehicles + products + optional admin; `npm run seed:admin` admin only)
# Default admin email for seed:admin is admin@treadtrails.com if SEED_ADMIN_EMAIL is omitted.
# SEED_ADMIN_EMAIL=admin@treadtrails.com
# SEED_ADMIN_PASSWORD=your-secure-password-at-least-8-chars
# SEED_ADMIN_NAME=Studio Admin
